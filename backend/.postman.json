      "GET /trending/opportunities",
      "GET /trending/categories",
      "GET /trending/regions"
    ],
    "youtube": [
      "GET /youtube/oauth/authorize",
      "GET /youtube/oauth/callback",
      "GET /youtube/channels",
      "POST /youtube/channels/{channel_id}/sync",
      "GET /youtube/channels/{channel_id}/videos",
      "DELETE /youtube/channels/{channel_id}"
